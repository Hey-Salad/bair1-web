# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Sensor ingestion API key (must match firmware + relay config)
SENSOR_API_KEY=generate-a-random-hex-string

# Auth0 (public SPA credentials)
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-client-id

# Mapbox (public token)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
